{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build:site",
  "outputDirectory": "_site",
  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "level0.andraewilliams.com"
        }
      ],
      "destination": "/level-0/:path*"
    }
  ]
}
